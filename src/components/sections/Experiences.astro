---
const { section, resume } = Astro.props;

const experiences = [
  {
    id: "sirius",
    company: "Sirius Tech SRL",
    logo: "/companies/sirius.webp",
    role: "Wordpress Developer",
    period: "Enero 2026 — ACTUALIDAD",
    description:
      "Empresa de tecnología especializada en brindar soluciones integrales tanto para el sector residencial como empresarial en República Dominicana.",
    projects: [
      {
        category: "DISEÑO",
        title: "Wordpress Developer",
        description: [
          "Diseño en Wordpress a medida según requerimientos del cliente y necesidades del proyecto.",
          "Creación de página web mediante la integración de CMS, Plugins eficientes y Metodologías Ágiles.",
          "Optimización de la página web para SEO.",
        ],

        metrics: [
          { label: "IMPACTO", value: "+99% Social" },
          { label: "Modalidad", value: "Remoto" },
          { label: "Tecnologías", value: "Wordpress, Elementor, SEO" },
        ],
      },
    ],
  },
  {
    id: "sinergia",
    company: "Grupo Sinergia",
    logo: "/companies/sinergia.webp",
    role: "Fullstack Developer",
    period: "Febrero 2026 — Marzo 2026",
    description:
      "Conglomerado de expertos especializados en recuperación y adecuación de infraestructura para potenciar la producción de crudo y gas.",
    projects: [
      {
        category: "FULL-STACK",
        title: "Fullstack Developer",
        description: [
          "Liderazgo técnico en la planificación y desarrollo de una pagina web para el sector petrolero, priorizando el rendimiento en producción con Astro.js.",
          "Implemetación de servicio de correo electrónico eficiente.",
          "Optimización del flujo de trabajo mediante herramientas y agentes de IA, logrando un desarrollo de código más limpio, rápido y eficiente.",
        ],
        metrics: [
          { label: "Rendimiento", value: "100%" },
          { label: "Modalidad", value: "Remoto" },
          { label: "Tecnologías", value: "Astro.js, TypeScript, Tailwind CSS" },
        ],
      },
    ],
  },
  {
    id: "parisca",
    company: "PariscaNovedades C.A",
    logo: "/companies/parisca.webp",
    role: "Gestor Y Analista de Datos",
    period: "Agosto 2024 — Mayo 2025",
    description:
      "Distribuidora de ropa con las mejores marcas nacionales e importadas de Perú.",
    projects: [
      {
        category: "ANÁLISIS DE DATOS",
        title: "Gestor Y Analista de Datos",
        description: [
          "Migración integral de inventario físico a plataformas digitales (Excel), eliminando la dependencia de registros manuales.",
          "Diseño e implementación de un control de inventario para una manipulación segura y eficiente de los datos.",
          "Generación de reportes semanales de ventas y rendimiento de productos.",
        ],
        metrics: [
          { label: "EFICTIVIDAD", value: "+100 Productos" },
          { label: "Modalidad", value: "Remoto" },
          {
            label: "Tecnologías",
            value: "Excel, Google Sheets, Microsoft Office",
          },
        ],
      },
    ],
  },
];
---

<section
  id="experiences"
  class="w-full py-24 px-6 md:px-12 lg:px-24 bg-[#fcfcfc] dark:bg-slate-950 text-slate-900 dark:text-slate-100 transition-colors duration-300"
>
  <div class="max-w-7xl mx-auto">
    <header
      class="flex justify-center items-center flex-col mb-30 text-center lg:text-left space-y-4"
    >
      <span
        class="block text-xs font-bold tracking-[0.2em] text-slate-500 uppercase"
      >
        {section || "TRAYECTORIA"}
      </span>
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight">
        Experiencia <span class="text-blue-600 dark:text-sky-800"
          >Profesional</span
        >
      </h2>
      {
        resume && (
          <p class="text-lg text-center md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl leading-relaxed">
            {resume}.
          </p>
        )
      }
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 items-start">
      <!-- Sidebar Navigation -->
      <nav class="flex flex-col gap-2" aria-label="Selección de experiencia">
        {
          experiences.map((exp, index) => (
            <button
              class={`exp-item group relative p-6 text-left rounded-2xl transition-all duration-300 border border-transparent ${index === 0 ? "bg-slate-900 shadow-xl shadow-black/5 dark:shadow-none border-slate-100 dark:border-white/10 active-state" : "bg-slate-900 hover:bg-slate-900"}`}
              data-target={exp.id}
            >
              <div class="flex items-center gap-3">
                <div class="shrink-0 w-9 h-9 bg-white border border-slate-200 dark:border-white/10 rounded-lg flex items-center justify-center overflow-hidden p-1">
                  <img
                    src={exp.logo}
                    alt={exp.company}
                    class="w-full h-full object-contain"
                    loading="lazy"
                  />
                </div>
                <div class="space-y-1">
                  <span class="block text-[10px] font-bold tracking-wider text-slate-400 uppercase">
                    {exp.period}
                  </span>
                  <h3 class="text-lg font-bold text-slate-200 dark:text-slate-100 group-[.active-state]:text-blue-600 dark:group-[.active-state]:text-blue-400 transition-colors">
                    {exp.company}
                  </h3>
                  <p class="text-sm text-slate-200 dark:text-slate-300">
                    {exp.role}
                  </p>
                </div>
              </div>
              <div
                class={`absolute right-6 top-1/2 -translate-y-1/2 w-1.5 h-1.5 bg-blue-600 dark:bg-blue-500 rounded-full transition-opacity duration-300 ${index === 0 ? "opacity-100" : "opacity-0"} indicator`}
              />
            </button>
          ))
        }
      </nav>

      <!-- Content Area -->
      <main class="relative min-h-[400px]">
        {
          experiences.map((exp, index) => (
            <div
              class={`content-item transition-all duration-500 transform ${index === 0 ? "opacity-100 translate-y-0 relative" : "opacity-0 translate-y-4 absolute inset-0 pointer-events-none"}`}
              id={`content-${exp.id}`}
            >
              <header class="flex items-center gap-6 mb-12">
                <div class="shrink-0 w-14 h-14 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl flex items-center justify-center shadow-sm overflow-hidden">
                  <img
                    src={exp.logo}
                    alt={exp.company}
                    class="w-full h-full object-contain"
                    loading="lazy"
                  />
                </div>
                <div>
                  <h3 class="text-xl md:text-2xl font-bold dark:text-white leading-none mb-2">
                    {exp.company}
                  </h3>
                  <p class="text-slate-500 dark:text-slate-400 max-w-xl">
                    {exp.description}
                  </p>
                </div>
              </header>

              <div class="space-y-8">
                {exp.projects.map((project) => (
                  <article class="group bg-slate-900 rounded-[2rem] p-8 md:p-10 backdrop-blur-sm border-b-4 border-slate-600  shadow-2xl shadow-slate-700 dark:bg-slate-900 dark:border-sky-900 dark:shadow-sky-950">
                    <div class="w-full">
                      <div class="space-y-6">
                        <header>
                          <h4 class="text-2xl font-bold text-slate-100">
                            {project.title}
                          </h4>
                        </header>

                        <ul class="list-disc list-outside ml-4 space-y-2 text-slate-300 leading-relaxed text-lg">
                          {Array.isArray(project.description) ? (
                            project.description.map((item) => (
                              <li class="text-sm md:text-md lg:text-lg tracking-wide font-normal">
                                {item}
                              </li>
                            ))
                          ) : (
                            <li class="text-sm">{project.description}</li>
                          )}
                        </ul>

                        <footer class="pt-8 border-t border-white/20 dark:border-white/5 flex flex-wrap justify-between items-end gap-6">
                          <div class="flex gap-10">
                            {project.metrics.map((metric) => (
                              <div class="space-y-1">
                                <span class="block text-[10px] font-bold text-slate-400 uppercase">
                                  {metric.label}
                                </span>
                                <span class="block text-sm md:text-xl font-semibold text-slate-100">
                                  {metric.value}
                                </span>
                              </div>
                            ))}
                          </div>
                        </footer>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          ))
        }
      </main>
    </div>
  </div>
</section>

<script>
  function initExperience() {
    const buttons = document.querySelectorAll(".exp-item");
    const contents = document.querySelectorAll(".content-item");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-target");

        // Update active button state
        buttons.forEach((b) => {
          b.classList.remove(
            "shadow-xl",
            "shadow-black/5",
            "dark:shadow-none",
            "border-slate-100",
            "dark:border-white/10",
            "active-state",
          );
          b.classList.add("border-transparent", "hover:bg-slate-900");
          const indicator = b.querySelector(".indicator");
          if (indicator)
            indicator.classList.replace("opacity-100", "opacity-0");
        });

        btn.classList.add(
          "shadow-xl",
          "shadow-black/5",
          "dark:shadow-none",
          "border-slate-100",
          "dark:border-white/10",
          "active-state",
        );
        btn.classList.remove("border-transparent", "hover:bg-slate-900");
        const activeIndicator = btn.querySelector(".indicator");
        if (activeIndicator)
          activeIndicator.classList.replace("opacity-0", "opacity-100");

        // Update active content with animation
        contents.forEach((content) => {
          if (content.id === `content-${target}`) {
            content.classList.remove(
              "opacity-0",
              "translate-y-4",
              "absolute",
              "pointer-events-none",
            );
            content.classList.add("opacity-100", "translate-y-0", "relative");
          } else {
            content.classList.remove(
              "opacity-100",
              "translate-y-0",
              "relative",
            );
            content.classList.add(
              "opacity-0",
              "translate-y-4",
              "absolute",
              "pointer-events-none",
            );
          }
        });
      });
    });
  }

  document.addEventListener("astro:page-load", initExperience);
  initExperience();
</script>
