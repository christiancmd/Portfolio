---
import { Image } from "astro:assets";

interface Props {
  section: string;
  resume: string;
  warning: string;
}

const { section, resume, warning } = Astro.props;

const image = "/certificatesection.jpeg";

const certificates = [
  {
    name: "Inglés Conversacional de Nivel Básico A1-A2",
    college: "SPEED UP LEARNING",
    date: "Sep 2024 - Ene 2025",
    status: "Completado",
  },
  {
    name: "Ingles Conversacional de Nivel Intermedio B1-B2",
    college: "SPEED UP LEARNING",
    date: "Oct 2025 - Feb 2026",
    status: "Completado",
  },
  {
    name: "Ingles Conversacional de Nivel Avanzado C1",
    college: "SPEED UP LEARNING",
    date: "Feb 2026 - Jul 2026",
    status: "Desarrollo",
  },
];
---

<section
  id="certificates"
  class="w-full text-center container mx-auto max-w-6xl px-2 lg:px-0"
>
  <span
    class="block text-gray-600 font-semibold tracking-wider uppercase text-sm my-8"
    >{section}</span
  >

  <hgroup class="space-y-1 text-center flex flex-col items-center">
    <h3
      class="font-extrabold text-3xl md:text-4xl lg:text-5xl tracking-tight text-gray-900 leading-tight dark:text-white pt-12"
    >
      Certificados <span class="text-blue-600 dark:text-sky-800">Obtenidos</span
      >
    </h3>
    {/* Línea decorativa */}
    <div
      class="h-1.5 w-24 bg-linear-to-r from-gray-600 to-blue-500 rounded-full mb-6"
    >
    </div>
    <p
      class="text-[16px] md:text-lg lg:text-xl text-slate-600 max-w-2xl leading-relaxed dark:text-slate-300"
    >
      {resume}
    </p>
  </hgroup>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mt-16">
    <div class="order-2 lg:order-1 space-y-6">
      <div class="space-y-4">
        {
          certificates.map((cert) => (
            <details class="group border text-left border-gray-200 dark:border-slate-800 rounded-xl bg-gray-200 dark:bg-slate-900 transition-all duration-300 hover:ring-1 hover:ring-blue-500 open:ring-1 open:ring-blue-500">
              <summary class="flex justify-between items-center p-5 cursor-pointer list-none focus:outline-none">
                <span class="font-semibold text-md lg:text-lg text-gray-800 dark:text-gray-200 group-open:text-blue-600 transition-colors">
                  {cert.name}
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-gray-400 group-open:rotate-180 transition-transform duration-300"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="Wait 19 9l-7 7-7-7"
                  />
                </svg>
              </summary>

              <div class="px-5 pb-5 text-medium text-gray-600 dark:text-gray-400 border-t border-gray-200 dark:border-slate-800 pt-4 animate-fadeIn">
                <p class="mb-1">
                  <strong class="text-gray-900 dark:text-white">
                    Institución:
                  </strong>{" "}
                  {cert.college}
                </p>
                <p class="mb-1">
                  <strong class="text-gray-900 dark:text-white">
                    Periodo:
                  </strong>{" "}
                  {cert.date}
                </p>
                <p>
                  <strong class="text-gray-900 dark:text-white">Estado:</strong>
                  <span
                    class={
                      cert.status === "Completado"
                        ? "text-green-600 font-medium"
                        : "text-amber-500 font-medium"
                    }
                  >
                    {cert.status}
                  </span>
                </p>
              </div>
            </details>
          ))
        }
      </div>
    </div>

    <div class="order-1 lg:order-2 flex justify-center items-center relative">
      <div class="relative group">
        <Image
          src={image}
          alt="Christian"
          width={400}
          height={400}
          class="rounded-2xl object-cover shadow-2xl transition-all duration-500 border-4 border-white dark:border-slate-800 w-72 h-72 md:w-96 md:h-96"
        />
      </div>
    </div>
  </div>

  <p class="text-left text-sm text-gray-600 dark:text-gray-400 mt-8 lg:mt-0">
    {warning}
  </p>
</section>

<style>
  /* Animación simple para la expansión */
  .animate-fadeIn {
    animation: fadeIn 0.3s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Quitar la flecha por defecto de details en Safari/Chrome */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
